{
  "manifest_version": 3,
  "name": "Iframe Extractor & Player Pro",
  "version": "10.0",
  "description": "Ultra-Robust tool to extract and play video streams with stealth mode and security policy stripping (CORP/COEP/COOP).",
  "permissions": [
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess",
    "tabs",
    "activeTab",
    "storage",
    "scripting",
    "cookies",
    "webNavigation",
    "webRequest",
    "privacy",
    "declarativeNetRequestFeedback"
  ],
  "host_permissions": [
    "*://*.aifvfjuf56juh.cfd/*",
    "*://www.808ball12.com/*",
    "*://*.livesports077.com/*",
    "*://*.shop/*",
    "*://*.xyz/*",
    "*://*.live/*",
    "*://*.stream/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; img-src * data:; frame-src https: http: *"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["player.html", "bypass.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
